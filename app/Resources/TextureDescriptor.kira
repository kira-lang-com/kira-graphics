struct TextureDescriptor {
    var label: String = ""
    var width: Int = 1
    var height: Int = 1
    var format: Int
    var usage: Int
    var sampleCount: Int = 1
    var storageMode: Int
}

struct SamplerDescriptor {
    var label: String = ""
    var minFilter: Int
    var magFilter: Int
    var addressModeU: Int
    var addressModeV: Int
}
