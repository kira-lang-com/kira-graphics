    var depthWriteEnabled: Bool = false
}

type RenderPipelineDescriptor {
    var label: String = ""
    var shader: GraphicsShader
    var vertexLayout: VertexLayoutDescriptor
    var primitiveType: PrimitiveType
    var colorAttachments: [ColorTargetDescriptor]
    var hasDepthFormat: Bool = false
    var depthFormat: TextureFormat
    var depthState: DepthState
    var cullMode: CullMode
    var windingOrder: WindingOrder
    var sampleCount: Int = 1
    var indexType: IndexType
}

type RenderPipeline {
    var descriptor: RenderPipelineDescriptor
}

type ComputePipelineDescriptor {
    var label: String = ""
    var shader: GraphicsShader
}

type ComputePipeline {
    var descriptor: ComputePipelineDescriptor
}

type BindGroupLayoutEntry {
    var bindingIndex: Int = 0
    var resourceBindingType: ResourceBindingType
    var stages: ShaderStageSet
}

type BindGroupLayoutDescriptor {
    var label: String = ""
    var entries: [BindGroupLayoutEntry]
}

type BindGroupLayout {
    var descriptor: BindGroupLayoutDescriptor
}

