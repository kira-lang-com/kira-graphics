    var width: Int = 1280
    var height: Int = 720
}

type TextureSize {
    var width: Int = 1
    var height: Int = 1
    var depth: Int = 1
}

type TextureFormat {
    var value: Int = 1
}

type BufferUsage {
    var value: Int = 0
}

type TextureUsage {
    var value: Int = 0
}

type StorageMode {
    var value: Int = 0
}

type LoadAction {
    var value: Int = 2
}

type StoreAction {
    var value: Int = 1
}

type PrimitiveType {
    var value: Int = 0
}

type IndexType {
    var value: Int = 0
}

type CullMode {
    var value: Int = 0
}

type WindingOrder {
    var value: Int = 1
}

type CompareFunction {
    var value: Int = 0
}

type BlendFactor {
    var value: Int = 1
}

type BlendOperation {
    var value: Int = 0
}

type FilterMode {
    var value: Int = 1
}

type AddressMode {
    var value: Int = 0
}

type VertexStepFunction {
    var value: Int = 0
}

type ResourceBindingType {
    var value: Int = 0
}

type ShaderStageSet {
    var vertex: Bool = false
    var fragment: Bool = false
    var compute: Bool = false
}

type GraphicsShaderSource {
    var shaderMode: Int = 0
    var vertexSource: String = ""
    var fragmentSource: String = ""
    var computeSource: String = ""
    var shaderAssetsDirectory: String = ""
    var shaderName: String = ""

    function useInlineGlsl(vertexSource: String, fragmentSource: String) {
        shaderMode = 0
        self.vertexSource = vertexSource
        self.fragmentSource = fragmentSource
        computeSource = ""
        shaderAssetsDirectory = ""
        shaderName = ""
        return
    }

    function useKslAssets(shaderAssetsDirectory: String, shaderName: String) {
        shaderMode = 1
        self.shaderAssetsDirectory = shaderAssetsDirectory
        self.shaderName = shaderName
        vertexSource = ""
        fragmentSource = ""
        computeSource = ""
        return
    }
}

type GraphicsShaderReflection {
    var shaderName: String = ""
    var vertexEntryPoint: String = "main"
    var fragmentEntryPoint: String = "main"
    var computeEntryPoint: String = "main"
    var vertexLayout: String = ""
    var resources: [String]
    var uniformBlocks: [String]
}

type GraphicsShaderDescriptor {
    var label: String = ""
    var source: GraphicsShaderSource
    var reflection: GraphicsShaderReflection
}

type GraphicsShader {
    var descriptor: GraphicsShaderDescriptor
}

type GraphicsBufferDescriptor {
