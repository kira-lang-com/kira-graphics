import KiraGraphics

@Main
@Native
function main() {
    var app = GraphicsApplication {
        title: "Kira Graphics Clear Color"
        width: 640
        height: 480
        sampleCount: 1
    }

    app.onFrame { frame in
        frame.pass(Color {
            r: 0.08
            g: 0.12
            b: 0.16
            a: 1.0
        }) { encoder in
            return
        }
        frame.requestQuit()
        return
    }

    app.run(0)
    return
}
