    var magFilter: FilterMode
    var mipFilter: FilterMode
    var addressModeS: AddressMode
    var addressModeT: AddressMode
    var addressModeR: AddressMode
    var lodMinClamp: Float = 0.0
    var lodMaxClamp: Float = 1000.0
    var maxAnisotropy: Int = 1
}

type GraphicsSampler {
