    var x: Float = 0.0
    var y: Float = 0.0
    var z: Float = 0.0
}

type Float4 {
    var r: Float = 0.0
    var g: Float = 0.0
    var b: Float = 0.0
    var a: Float = 1.0
}

type Float4x4 {
    var m00: Float = 1.0
    var m01: Float = 0.0
    var m02: Float = 0.0
    var m03: Float = 0.0
    var m10: Float = 0.0
    var m11: Float = 1.0
    var m12: Float = 0.0
    var m13: Float = 0.0
    var m20: Float = 0.0
    var m21: Float = 0.0
    var m22: Float = 1.0
    var m23: Float = 0.0
    var m30: Float = 0.0
    var m31: Float = 0.0
    var m32: Float = 0.0
    var m33: Float = 1.0
}

