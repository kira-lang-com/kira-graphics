type GraphicsConstants {
    let shaderModeInlineGlsl: Int = 0
    let shaderModeKslAssets: Int = 1

    let storageModeShared: Int = 0
    let storageModeManaged: Int = 1
    let storageModePrivate: Int = 2

    let bufferUsageVertex: Int = 0
    let bufferUsageIndex: Int = 1
    let bufferUsageUniform: Int = 2
    let bufferUsageStorage: Int = 3

    let textureUsageShaderRead: Int = 0
    let textureUsageRenderTarget: Int = 1
    let textureUsageShaderWrite: Int = 2

    let textureFormatInvalid: Int = 0
    let textureFormatBgra8Unorm: Int = 1
    let textureFormatRgba8Unorm: Int = 2
    let textureFormatRgba16Float: Int = 3
    let textureFormatDepth32Float: Int = 4

    let loadActionDontCare: Int = 0
    let loadActionLoad: Int = 1
    let loadActionClear: Int = 2

    let storeActionDontCare: Int = 0
    let storeActionStore: Int = 1

    let primitiveTypeTriangle: Int = 0
    let primitiveTypeTriangleStrip: Int = 1
    let primitiveTypeLine: Int = 2
    let primitiveTypePoint: Int = 3

    let indexTypeNone: Int = 0
    let indexTypeUint16: Int = 1
    let indexTypeUint32: Int = 2

    let cullModeNone: Int = 0
    let cullModeFront: Int = 1
    let cullModeBack: Int = 2

    let windingClockwise: Int = 0
    let windingCounterClockwise: Int = 1

    let compareAlways: Int = 0
    let compareLess: Int = 1
    let compareLessEqual: Int = 2
    let compareGreater: Int = 3
    let compareEqual: Int = 4

    let blendFactorZero: Int = 0
    let blendFactorOne: Int = 1
    let blendFactorSourceAlpha: Int = 2
    let blendFactorOneMinusSourceAlpha: Int = 3

    let blendOpAdd: Int = 0
    let blendOpSubtract: Int = 1

    let filterNearest: Int = 0
    let filterLinear: Int = 1

    let addressModeClampToEdge: Int = 0
    let addressModeRepeat: Int = 1
    let addressModeMirrorRepeat: Int = 2

    let vertexStepPerVertex: Int = 0
    let vertexStepPerInstance: Int = 1

    let resourceBindingUniformBuffer: Int = 0
    let resourceBindingStorageBuffer: Int = 1
    let resourceBindingTexture: Int = 2
    let resourceBindingSampler: Int = 3
}

type Float2 {
    var x: Float = 0.0
    var y: Float = 0.0
}

