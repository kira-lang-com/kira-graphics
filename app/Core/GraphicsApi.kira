    var format: TextureFormat
    var byteOffset: Int = 0
    var bufferIndex: Int = 0
    var shaderLocation: Int = 0
}

type VertexBufferLayoutDescriptor {
    var stride: Int = 0
    var stepFunction: VertexStepFunction
    var stepRate: Int = 1
}

type VertexLayoutDescriptor {
    var label: String = ""
    var layoutText: String = ""
    var attributes: [VertexAttributeDescriptor]
    var bufferLayouts: [VertexBufferLayoutDescriptor]
}

type BlendComponent {
    var sourceFactor: BlendFactor
    var destinationFactor: BlendFactor
    var operation: BlendOperation
}

type ColorTargetDescriptor {
    var textureFormat: TextureFormat
    var blendingEnabled: Bool = false
    var rgbBlend: BlendComponent
    var alphaBlend: BlendComponent
    var writeRed: Bool = true
    var writeGreen: Bool = true
    var writeBlue: Bool = true
    var writeAlpha: Bool = true
}

type DepthState {
