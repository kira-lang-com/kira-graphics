+            count,
+            x + w * 0.5,
+            y + h * 0.5,
+            (float)border_r,
+            (float)border_g,
+            (float)border_b,
+            (float)border_a
+        );
+    }
+
+    if (a <= 0.0) {
+        return;
+    }
+
+    double inset = border_width > 0.0 ? border_width : 0.0;
+    double inner_x = x + inset;
+    double inner_y = y + inset;
+    double inner_w = w - inset * 2.0;
+    double inner_h = h - inset * 2.0;
+
+    if (inner_w <= 0.0 || inner_h <= 0.0) {
+        return;
+    }
