    var usage: BufferUsage
    var storageMode: StorageMode
    var byteCount: Int = 0
    var stride: Int = 0
    var floatData: [Float]
    var integerData: [Int]
}

type GraphicsBuffer {
    var descriptor: GraphicsBufferDescriptor
