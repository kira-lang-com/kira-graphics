    var byteOffset: Int = 0
    var byteCount: Int = 0
}

type BindGroupResourceBinding {
    var resourceBindingType: ResourceBindingType
    var bufferBinding: GraphicsBufferBinding
    var texture: GraphicsTexture
    var sampler: GraphicsSampler
}

type BindGroupDescriptor {
    var label: String = ""
